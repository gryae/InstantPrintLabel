<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="min-h-full bg-surface-950 text-slate-100">

  <%- include('../partials/navbar', { activePage: 'packing-lists' }) %>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Page header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="page-title"><%= __('pl_title') %></h1>
        <p class="page-subtitle"><%= __('pl_subtitle') %></p>
      </div>
      <a href="/packing-lists/upload" id="uploadBtn" class="btn btn-primary">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
        </svg>
        <%= __('pl_upload_new') %>
      </a>
    </div>

    <%- include('../partials/flash') %>

    <% if (!lists || lists.length === 0) { %>
      <!-- Empty state -->
      <div class="card text-center py-16 animate-fade-in">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-surface-800 border border-surface-700/50 mb-4 mx-auto">
          <svg class="w-8 h-8 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-slate-300 mb-2"><%= __('pl_no_lists') %></h2>
        <p class="text-slate-500 text-sm mb-6"><%= __('pl_no_lists_desc') %></p>
        <a href="/packing-lists/upload" class="btn btn-primary inline-flex">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          <%= __('pl_btn_upload') %>
        </a>
      </div>
    <% } else { %>

      <!-- Stats row -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div class="card card-body flex items-center gap-4">
          <div class="w-10 h-10 rounded-xl bg-brand-900/30 border border-brand-700/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div>
            <p class="text-2xl font-bold text-slate-100"><%= lists.length %></p>
            <p class="text-xs text-slate-400 font-medium"><%= __('pl_total_lists') %></p>
          </div>
        </div>
        <div class="card card-body flex items-center gap-4">
          <div class="w-10 h-10 rounded-xl bg-emerald-900/30 border border-emerald-700/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
          </div>
          <div>
            <p class="text-2xl font-bold text-slate-100"><%= lists.reduce((s, l) => s + (l.item_count || 0), 0) %></p>
            <p class="text-xs text-slate-400 font-medium"><%= __('pl_total_items') %></p>
          </div>
        </div>
        <div class="card card-body flex items-center gap-4">
          <div class="w-10 h-10 rounded-xl bg-amber-900/30 border border-amber-700/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
            </svg>
          </div>
          <div>
            <p class="text-2xl font-bold text-slate-100"><%= lists.reduce((s, l) => s + (l.print_count || 0), 0) %></p>
            <p class="text-xs text-slate-400 font-medium"><%= __('pl_total_prints') %></p>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div class="card overflow-hidden animate-slide-up">
        <div class="card-header flex items-center justify-between">
          <h2 class="font-semibold text-slate-200 flex items-center gap-2">
            <svg class="w-4 h-4 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            <%= __('pl_all_lists') %>
          </h2>
          <span class="badge badge-brand"><%= lists.length %> <%= __('pl_files') %></span>
        </div>
        <div class="overflow-x-auto">
          <table class="table-base" id="packingListsTable">
            <thead>
              <tr>
                <th>#</th>
                <th><%= __('pl_col_filename') %></th>
                <th><%= __('pl_col_items') %></th>
                <th><%= __('pl_col_prints') %></th>
                <th><%= __('pl_col_uploaded_by') %></th>
                <th><%= __('pl_col_uploaded_at') %></th>
                <th class="text-right"><%= __('pl_col_actions') %></th>
              </tr>
            </thead>
            <tbody>
              <% lists.forEach(function(list, idx) { %>
              <tr class="animate-fade-in">
                <td class="font-mono text-slate-500 text-xs"><%= idx + 1 %></td>
                <td>
                  <div class="flex items-center gap-2.5">
                    <div class="w-8 h-8 rounded-lg bg-brand-900/25 border border-brand-700/20 flex items-center justify-center flex-shrink-0">
                      <svg class="w-4 h-4 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                    </div>
                    <div>
                      <p class="font-medium text-slate-200 text-sm truncate max-w-xs"><%= list.original_name || list.filename %></p>
                      <p class="text-xs text-slate-600 font-mono"><%= list.filename %></p>
                    </div>
                  </div>
                </td>
                <td><span class="badge badge-brand"><%= list.item_count %> <%= __('pl_status_items') %></span></td>
                <td>
                  <% if (list.print_count > 0) { %>
                    <span class="badge badge-success"><%= list.print_count %> <%= __('pl_status_prints') %></span>
                  <% } else { %>
                    <span class="badge badge-checker"><%= __('pl_status_not_printed') %></span>
                  <% } %>
                </td>
                <td>
                  <div class="flex items-center gap-1.5">
                    <div class="w-5 h-5 rounded-full bg-gradient-to-br from-brand-600 to-brand-800 flex items-center justify-center">
                      <span class="text-[9px] font-bold text-white"><%= list.uploaded_by_name.charAt(0).toUpperCase() %></span>
                    </div>
                    <span class="text-slate-300 text-sm"><%= list.uploaded_by_name %></span>
                  </div>
                </td>
                <td class="text-slate-500 text-xs">
                  <%= new Date(list.uploaded_at).toLocaleString('en-GB', { dateStyle: 'medium', timeStyle: 'short' }) %>
                </td>
                <td class="text-right">
                  <div class="flex items-center justify-end gap-2">
                    <a href="/packing-lists/<%= list.id %>" id="viewList<%= list.id %>" class="btn btn-secondary btn-sm">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                      </svg>
                      <%= __('pl_action_view') %>
                    </a>
                    <button type="button" id="printList<%= list.id %>" onclick="openQuickPrint(<%= list.id %>, <%= list.has_no_do === 1 %>)" class="btn btn-success btn-sm">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                      </svg>
                      <%= __('pl_action_print') %>
                    </button>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    <% } %>
  </main>

  <footer class="border-t border-surface-700/30 py-4 mt-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs text-slate-600 text-center">PrintLabel &copy; <%= new Date().getFullYear() %></p>
    </div>
  </footer>

  <!-- Quick Print Modal (from index list) -->
  <div id="quickPrintModal" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.65);backdrop-filter:blur(4px);" onclick="closeQuickPrint(event)">
    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:#0f172a;border:1px solid rgba(51,65,85,0.6);border-radius:16px;padding:28px;min-width:340px;max-width:440px;width:90%;" onclick="event.stopPropagation()">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;">
        <div style="width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,#0d9488,#0f766e);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg style="width:18px;height:18px;" fill="none" viewBox="0 0 24 24" stroke="white" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" /></svg>
        </div>
        <h3 style="font-size:1rem;font-weight:700;color:#f1f5f9;margin:0;"><%= __('pl_modal_title') %></h3>
        <button onclick="closeQuickPrint()" style="margin-left:auto;background:none;border:none;color:#64748b;cursor:pointer;padding:4px;" onmouseover="this.style.color='#e2e8f0'" onmouseout="this.style.color='#64748b'">
          <svg style="width:18px;height:18px;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <form id="quickPrintForm" method="POST">
        <label style="display:block;font-size:0.75rem;font-weight:700;color:#94a3b8;margin-bottom:6px;letter-spacing:0.05em;text-transform:uppercase;"><%= __('pl_modal_cust_name') %></label>
        <input id="quickCustomerName" type="text" name="customerName" placeholder="e.g. PT. Sutorang Jaya" required autocomplete="off"
          style="width:100%;padding:10px 14px;background:#020617;border:1px solid #334155;border-radius:10px;color:#f1f5f9;font-size:0.875rem;outline:none;box-sizing:border-box;margin-bottom:6px;"
          onfocus="this.style.borderColor='#14b8a6'" onblur="this.style.borderColor='#334155'"/>
        <p style="font-size:0.72rem;color:#475569;margin:0 0 20px;"><%= __('pl_modal_cust_desc') %></p>
        
        <!-- Dynamic reset checkbox -->
        <div id="quickResetBoxContainer" style="display: none; margin-bottom: 24px; align-items: flex-start; gap: 10px;">
          <input type="checkbox" id="quickResetBoxPerDo" name="resetBoxPerDo" value="true"
            style="margin-top: 4px; width: 16px; height: 16px; accent-color: #14b8a6; cursor: pointer;" checked />
          <div style="display: flex; flex-direction: column; gap: 2px;">
            <label for="quickResetBoxPerDo" style="font-size: 0.85rem; font-weight: 600; color: #e2e8f0; cursor: pointer;">
              <%= __('pl_modal_reset_box') %>
            </label>
            <p style="font-size: 0.72rem; color: #64748b; margin: 0;">
              <%= __('pl_modal_reset_box_desc') %>
            </p>
          </div>
        </div>

        <div style="display:flex;gap:10px;">
          <button type="button" onclick="closeQuickPrint()" style="flex:1;padding:10px;background:#1e293b;border:1px solid #334155;color:#94a3b8;border-radius:9999px;font-size:0.875rem;cursor:pointer;"><%= __('pl_modal_btn_cancel') %></button>
          <button type="submit" id="quickPrintSubmit" style="flex:2;padding:10px;background:linear-gradient(135deg,#0d9488,#0f766e);border:none;color:white;border-radius:9999px;font-size:0.875rem;font-weight:600;cursor:pointer;">
            <%= __('pl_modal_btn_submit') %>
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    var currentListId = null;
    function openQuickPrint(listId, hasNoDo) {
      currentListId = listId;
      document.getElementById('quickPrintForm').action = '/packing-lists/' + listId + '/print';
      
      const container = document.getElementById('quickResetBoxContainer');
      const checkbox = document.getElementById('quickResetBoxPerDo');
      if (hasNoDo) {
        container.style.display = 'flex';
        checkbox.checked = true;
      } else {
        container.style.display = 'none';
        checkbox.checked = false;
      }

      document.getElementById('quickPrintModal').style.display = 'block';
      setTimeout(() => document.getElementById('quickCustomerName').focus(), 50);
    }
    function closeQuickPrint(e) {
      if (!e || e.target === document.getElementById('quickPrintModal')) {
        document.getElementById('quickPrintModal').style.display = 'none';
        document.getElementById('quickCustomerName').value = '';
      }
    }
    document.getElementById('quickPrintForm').addEventListener('submit', function() {
      const btn = document.getElementById('quickPrintSubmit');
      btn.disabled = true; btn.style.opacity = '0.6'; btn.textContent = '<%= __('pl_modal_btn_loading') %>';
    });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeQuickPrint(); });
  </script>
  <script src="/js/app.js"></script>
</body>
</html>
