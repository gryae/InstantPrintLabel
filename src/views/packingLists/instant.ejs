<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="min-h-full bg-surface-950 text-slate-100">

  <%- include('../partials/navbar', { activePage: 'instant' }) %>

  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <div class="mb-6">
      <h1 class="page-title"><%= __('inst_title') %></h1>
      <p class="page-subtitle"><%= __('inst_subtitle') %></p>
    </div>

    <%- include('../partials/flash') %>

    <div class="card overflow-hidden animate-slide-up">
      <div class="h-1 bg-gradient-to-r from-teal-500 via-emerald-400 to-indigo-600"></div>
      <div class="card-body">

        <form action="/packing-lists/instant" method="POST" enctype="multipart/form-data" id="instantForm">

          <!-- Customer Name Input -->
          <div class="mb-6">
            <label for="customerName" style="display:block;font-size:0.75rem;font-weight:700;color:#94a3b8;margin-bottom:8px;letter-spacing:0.05em;text-transform:uppercase;">
              <%= __('pl_modal_cust_name') %>
            </label>
            <input
              id="customerName"
              type="text"
              name="customerName"
              placeholder="e.g. PT. Sutorang Jaya"
              required
              autocomplete="off"
              style="width:100%;padding:12px 16px;background:#020617;border:1px solid #334155;border-radius:10px;color:#f1f5f9;font-size:0.9rem;outline:none;box-sizing:border-box;"
              onfocus="this.style.borderColor='#14b8a6'"
              onblur="this.style.borderColor='#334155'"
            />
            <p style="font-size:0.72rem;color:#475569;margin-top:6px;">
              <%= __('pl_modal_cust_desc') %>
            </p>
          </div>

          <!-- Drop zone -->
          <div
            id="dropZone"
            class="relative border-2 border-dashed border-surface-600 rounded-xl p-12 text-center cursor-pointer
                   hover:border-teal-500 hover:bg-teal-900/10 transition-all duration-300 group"
          >
            <input
              type="file"
              id="packingListFile"
              name="packingListFile"
              accept=".xlsx,.xls"
              class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
              required
            />

            <div id="dropContent">
              <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-surface-800 border border-surface-700/50 mb-4 group-hover:bg-teal-900/30 group-hover:border-teal-700/40 transition-all duration-300">
                <svg class="w-7 h-7 text-slate-400 group-hover:text-teal-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
                </svg>
              </div>
              <p class="text-base font-semibold text-slate-300 mb-1"><%= __('up_drop_title') %></p>
              <p class="text-sm text-slate-500 mb-3"><%= __('up_drop_subtitle') %></p>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-surface-800 border border-surface-600 text-xs text-slate-400">
                <%= __('up_drop_limits') %>
              </span>
            </div>

            <div id="fileSelected" class="hidden">
              <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-teal-900/40 border border-teal-700/40 mb-4">
                <svg class="w-7 h-7 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <p class="text-base font-semibold text-teal-400 mb-1" id="selectedFileName">File selected</p>
              <p class="text-xs text-slate-500" id="selectedFileSize"></p>
            </div>
          </div>

          <!-- Requirements info -->
          <div class="mt-4 p-4 bg-surface-800/50 border border-surface-700/30 rounded-lg">
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-2 flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <%= __('up_requirements') %>
            </p>
            <ul class="space-y-1 text-xs text-slate-500">
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-teal-500 flex-shrink-0"></span>
                <%- __('up_req_sheet', '<strong class="text-slate-400 font-mono">PACKINGLIST</strong>') %>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-teal-500 flex-shrink-0"></span>
                <%- __('up_req_cols', '<strong class="text-slate-400">CODE, DESC, QTY, NO BOX, QTY OF BOX, WEIGHT(KG)</strong>') %>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-teal-500 flex-shrink-0"></span>
                <%= __('up_req_merged') %>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-teal-500 flex-shrink-0"></span>
                <%= __('up_req_ranges') %>
              </li>
            </ul>
          </div>

          <div class="flex justify-end mt-6">
            <button type="submit" id="instantSubmitBtn" class="btn btn-primary px-8 py-2.5 justify-center" style="background: linear-gradient(135deg,#0d9488,#0f766e);" disabled>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
              </svg>
              <%= __('inst_btn_print') %>
            </button>
          </div>
        </form>

      </div>
    </div>
  </main>

  <script src="/js/app.js"></script>
  <script>
    const fileInput    = document.getElementById('packingListFile');
    const dropZone     = document.getElementById('dropZone');
    const dropContent  = document.getElementById('dropContent');
    const fileSelected = document.getElementById('fileSelected');
    const fileNameEl   = document.getElementById('selectedFileName');
    const fileSizeEl   = document.getElementById('selectedFileSize');
    const submitBtn    = document.getElementById('instantSubmitBtn');
    const instantForm  = document.getElementById('instantForm');

    function formatBytes(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function showFile(file) {
      dropContent.classList.add('hidden');
      fileSelected.classList.remove('hidden');
      fileNameEl.textContent = file.name;
      fileSizeEl.textContent = formatBytes(file.size);
      submitBtn.disabled = false;
      dropZone.classList.add('border-teal-500', 'bg-teal-900/10');
    }

    fileInput.addEventListener('change', () => {
      if (fileInput.files.length) showFile(fileInput.files[0]);
    });

    // Drag-and-drop visual feedback
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('border-teal-400', 'bg-teal-900/20');
    });
    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('border-teal-400', 'bg-teal-900/20');
    });
    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('border-teal-400', 'bg-teal-900/20');
    });

    // Loading state on submit
    instantForm.addEventListener('submit', () => {
      submitBtn.disabled = true;
      submitBtn.innerHTML = `
        <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
        </svg>
        <%= __('inst_btn_loading') %>
      `;
    });
  </script>
</body>
</html>
