<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="min-h-full bg-surface-950 text-slate-100">

  <!-- Nav -->
  <header class="sticky top-0 z-50 bg-surface-900/80 backdrop-blur-md border-b border-surface-700/50 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/packing-lists" class="flex items-center gap-3">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center shadow-lg">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <span class="font-bold text-lg text-slate-100">PrintLabel</span>
        </a>
        <div class="flex items-center gap-3">
          <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-lg bg-surface-800 border border-surface-700/50">
            <div class="w-6 h-6 rounded-full bg-brand-600 flex items-center justify-center">
              <span class="text-xs font-bold text-white"><%= currentUser.name.charAt(0).toUpperCase() %></span>
            </div>
            <span class="text-sm text-slate-300 font-medium"><%= currentUser.name %></span>
          </div>
          <a href="/logout" class="btn btn-secondary btn-sm">Logout</a>
        </div>
      </div>
    </div>
  </header>

  <main class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-8">
      <a href="/packing-lists" class="hover:text-slate-300 transition-colors">Packing Lists</a>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      <a href="/packing-lists/<%= packingListId %>" class="hover:text-slate-300 transition-colors">Detail</a>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-slate-400">Print Labels</span>
    </nav>

    <!-- Icon -->
    <div class="text-center mb-8 animate-fade-in">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-emerald-600 to-emerald-800 shadow-2xl shadow-emerald-900/50 mb-4">
        <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
      </div>
      <h1 class="page-title">Print Labels</h1>
      <p class="page-subtitle mt-1">Enter the customer name to generate box labels</p>
    </div>

    <%- include('../partials/flash') %>

    <div class="card overflow-hidden animate-slide-up">
      <div class="h-1 bg-gradient-to-r from-emerald-500 via-emerald-400 to-emerald-600"></div>
      <div class="card-body">

        <!-- Preview of label format -->
        <div class="mb-6 p-4 bg-surface-800/60 border border-surface-700/30 rounded-xl">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-3">Label Preview</p>
          <div class="bg-yellow-300 rounded-lg p-4 text-black font-mono text-sm shadow-md">
            <div class="border-b-2 border-black pb-2 mb-2 font-bold text-center text-base" id="previewHeader">
              CUSTOMER NAME / NO BOX 1
            </div>
            <div class="space-y-1 text-xs py-2">
              <div>2DP-WE13E-00  CYLINDER & PISTON RING SET  10</div>
              <div>BK6-YM250-01  MAIN SW. STRG. LOCK SUB ASSY  20</div>
            </div>
            <div class="border-t-2 border-black pt-2 mt-2 text-xs">
              CHECK BY : <span id="previewChecker"><%= currentUser.name.toUpperCase() %></span>
              &nbsp;&nbsp;&nbsp;&nbsp;Weight 12 kgs
            </div>
          </div>
        </div>

        <form action="/packing-lists/<%= packingListId %>/print" method="POST" id="printForm">

          <div class="mb-5">
            <label for="customerName" class="label-text">Customer Name <span class="text-red-400">*</span></label>
            <input
              type="text"
              id="customerName"
              name="customerName"
              class="input text-lg font-semibold uppercase tracking-wide"
              placeholder="e.g. SUTORANG"
              autocomplete="off"
              required
              autofocus
            />
            <p class="text-xs text-slate-500 mt-1.5">
              Will appear as: <strong class="text-slate-300 font-mono" id="headerPreview">CUSTOMER NAME / NO BOX 1</strong>
            </p>
          </div>

          <!-- Info box -->
          <div class="p-3 bg-surface-800/50 border border-surface-700/30 rounded-lg mb-5">
            <div class="flex items-center gap-2 text-xs text-slate-400">
              <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              Checker: <strong class="text-slate-300"><%= currentUser.name %></strong>
              &nbsp;(auto-filled from your login)
            </div>
          </div>

          <div class="flex gap-3">
            <a href="/packing-lists/<%= packingListId %>" class="btn-secondary flex-1 justify-center">Cancel</a>
            <button type="submit" id="generateBtn" class="btn-success flex-1 justify-center py-3 font-semibold">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
              </svg>
              Generate &amp; Print
            </button>
          </div>
        </form>

      </div>
    </div>
  </main>

  <script src="/js/app.js"></script>
  <script>
    const customerInput  = document.getElementById('customerName');
    const headerPreview  = document.getElementById('headerPreview');
    const previewHeader  = document.getElementById('previewHeader');
    const generateBtn    = document.getElementById('generateBtn');
    const printForm      = document.getElementById('printForm');

    customerInput.addEventListener('input', () => {
      const val = customerInput.value.trim().toUpperCase() || 'CUSTOMER NAME';
      headerPreview.textContent = `${val} / NO BOX 1`;
      previewHeader.textContent = `${val} / NO BOX 1`;
    });

    printForm.addEventListener('submit', () => {
      generateBtn.disabled = true;
      generateBtn.innerHTML = `
        <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
        </svg>
        Generating...
      `;
    });
  </script>
</body>
</html>
