<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
    rel="stylesheet" />

  <style>
    /* ============================================================
       PRINT PAGE STYLES — 100mm × 100mm thermal label
       ============================================================ */

    @page {
      size: 100mm 100mm;
      margin: 0;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    /* Screen preview styles */
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #020617;
      color: #f1f5f9;
      padding: 24px;
    }

    /* ── No-print controls ── */
    .screen-controls {
      max-width: 900px;
      margin: 0 auto 24px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 16px 20px;
      background: #1e293b;
      border: 1px solid rgba(71, 85, 105, 0.4);
      border-radius: 12px;
    }

    .screen-controls .info {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .screen-controls .info h1 {
      font-size: 1rem;
      font-weight: 700;
      color: #f1f5f9;
    }

    .screen-controls .info p {
      font-size: 0.75rem;
      color: #64748b;
    }

    .btn-print {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      background: linear-gradient(135deg, #059669, #047857);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-print:hover {
      background: linear-gradient(135deg, #10b981, #059669);
      transform: scale(1.02);
    }

    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      background: #1e293b;
      border: 1px solid #334155;
      color: #94a3b8;
      border-radius: 8px;
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
    }

    .btn-back:hover {
      background: #334155;
      color: #e2e8f0;
    }

    /* Labels grid (screen) */
    .labels-container {
      max-width: 900px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(380px, 1fr));
      gap: 16px;
    }

    /* ── THE LABEL (screen) ── */
    .label-page {
      width: 380px;
      height: 380px;
      background: whitesmoke;
      border: 2px solid #111;
      border-radius: 4px;
      box-shadow: 0 4px 24px rgba(0, 0, 0, 0.5);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      overflow: hidden;
      font-family: 'Inter', system-ui, sans-serif;
    }

    /* Header */
    .label-header {
      background: whitesmoke;
      border-bottom: 2.5px solid #111;
      padding: 8px 10px;
      text-align: center;
    }

    .label-header h2 {
      font-size: 14px;
      font-weight: 800;
      color: #000;
      text-transform: uppercase;
      letter-spacing: 0.03em;
      line-height: 1.2;
    }

    /* Body — items list */
    .label-body {
      flex: 0 0 auto;
      padding: 6px 10px;
      overflow: hidden;
      background: whitesmoke;
    }

    .label-body table {
      width: 100%;
      border-collapse: collapse;
      font-size: 9px;
      color: #000;
    }

    .label-body table td {
      padding: 2px 2px;
      vertical-align: top;
      line-height: 1.3;
    }

    .label-body table .col-code {
      font-family: 'JetBrains Mono', monospace;
      font-weight: 600;
      white-space: nowrap;
      padding-right: 6px;
      color: #000;
      font-size: 8.5px;
    }

    .label-body table .col-desc {
      width: 100%;
      color: #000;
    }

    .label-body table .col-qty {
      font-weight: 700;
      text-align: right;
      white-space: nowrap;
      padding-left: 4px;
      font-size: 10px;
    }

    /* Footer */
    .label-footer {
      border-top: 2.5px solid #111;
      padding: 5px 10px;
      background: whitesmoke;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .label-footer .no-do-box {
      font-size: 9px;
      font-weight: 700;
      color: #000;
      text-transform: uppercase;
    }

    .label-footer .footer-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .label-footer .check-by {
      font-size: 8px;
      font-weight: 600;
      color: #000;
      text-transform: uppercase;
    }

    .label-footer .weight {
      font-size: 9px;
      font-weight: 700;
      color: #000;
      white-space: nowrap;
    }

    /* ============================================================
       PRINT STYLES — Override screen styles for 100mm×100mm
       ============================================================ */
    @media print {
      body {
        background: white;
        padding: 0;
        margin: 0;
      }

      .screen-controls,
      .labels-header {
        display: none !important;
      }

      .labels-container {
        display: block;
        margin: 0;
        padding: 0;
        max-width: none;
      }

      .label-page {
        width: 100mm;
        height: 100mm;
        max-height: 100mm;
        border-radius: 0;
        box-shadow: none;
        page-break-after: always;
        break-after: page;
        page-break-inside: avoid;
        break-inside: avoid;
        margin: 0;
        padding: 0;
        border: none;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
        /* Pastikan warna background muncul saat print */
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      /* Last label — no page break after */
      .label-page:last-child {
        page-break-after: avoid;
        break-after: avoid;
      }

      .label-header h2 {
        font-size: 11pt;
      }

      .label-body {
        flex: 0 0 auto;
        overflow: hidden;
      }

      .label-body table {
        font-size: 7pt;
      }

      .label-body table .col-code {
        font-size: 7pt;
      }

      .label-body table .col-qty {
        font-size: 8pt;
      }

      .label-footer {
        flex-shrink: 0;
        margin-top: auto;
      }

      .label-footer .no-do-box {
        font-size: 7pt;
      }

      .label-footer .check-by {
        font-size: 6.5pt;
      }

      .label-footer .weight {
        font-size: 7.5pt;
      }
    }
  </style>
</head>

<body>

  <!-- ── Screen-only controls ── -->
  <div class="screen-controls" id="screenControls">
    <div class="info">
      <h1>
        <svg style="display:inline;width:16px;height:16px;margin-right:4px;vertical-align:-2px" fill="none"
          viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
        Print Labels — <%= customerName %>
      </h1>
      <p>
        <%= labels.length %> box label<%= labels.length !==1 ? 's' : '' %> ready to print &nbsp;•&nbsp; Checker: <%=
              checkerName %> &nbsp;•&nbsp; <%= printDate %>
      </p>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
      <a href="javascript:history.back()" class="btn-back">
        <svg style="width:14px;height:14px" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back
      </a>
      <button onclick="window.print()" class="btn-print" id="printNowBtn">
        <svg style="width:16px;height:16px" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
        </svg>
        Print All <%= labels.length %> Label<%= labels.length !==1 ? 's' : '' %>
      </button>
    </div>
  </div>

  <!-- ── Labels ── -->
  <div class="labels-container" id="labelsContainer">
    <% labels.forEach(function(label) { %>
      <div class="label-page" id="label-box-<%= label.boxNo %>">

        <!-- HEADER: CUSTOMER / NO BOX N -->
        <div class="label-header">
          <h2>
            <%= label.headerText %>
          </h2>
        </div>

        <!-- BODY: Items table -->
        <div class="label-body">
          <table>
            <tbody>
              <% label.lineItems.forEach(function(li) { %>
                <tr>
                  <td class="col-code">
                    <%= li.code %>
                  </td>
                  <td class="col-desc">
                    <%= li.description %>
                  </td>
                  <td class="col-qty">
                    <%= li.qtyInBox %>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>

        <!-- FOOTER: NO DO/BOX (jika ada) + CHECK BY + WEIGHT -->
        <div class="label-footer">
          <% if (label.noDo) { %>
            <span class="no-do-box">NO DO / BOX : <%= label.noDo %> / <%= label.boxNo %></span>
          <% } %>
          <div class="footer-row">
            <span class="check-by">CHECK BY : <%= label.checkerName.toUpperCase() %> ,&nbsp; <%= printDate %></span>
            <span class="weight">Weight <%= parseFloat(label.weightKg).toFixed(0) %> kgs</span>
          </div>
        </div>

      </div>
      <% }) %>
  </div>

  <script>
    // Auto-trigger print dialog — tunggu font Google Fonts selesai load
    // supaya print dialog tidak kosong
    window.addEventListener('load', function () {
      var doPrint = function () {
        window.print();
      };

      if (document.fonts && document.fonts.ready) {
        // Tunggu semua font (termasuk Google Fonts) siap, lalu print
        document.fonts.ready.then(function () {
          // Tambah sedikit delay ekstra agar layout stabil
          setTimeout(doPrint, 300);
        });
      } else {
        // Fallback untuk browser lama
        setTimeout(doPrint, 1500);
      }
    });
  </script>
</body>

</html>