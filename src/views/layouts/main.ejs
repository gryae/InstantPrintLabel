<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="PrintLabel — Generate and print packing labels from Excel packing list files" />
  <title><%= typeof title !== 'undefined' ? title : 'PrintLabel' %></title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Tailwind compiled CSS -->
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="min-h-full flex flex-col">

  <!-- Top Navigation -->
  <% if (currentUser) { %>
  <header class="sticky top-0 z-50 bg-surface-900/80 backdrop-blur-md border-b border-surface-700/50 shadow-lg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">

        <!-- Logo -->
        <a href="/packing-lists" class="flex items-center gap-3 group">
          <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center shadow-lg shadow-brand-900/40 group-hover:scale-105 transition-transform duration-200">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <span class="font-bold text-lg text-slate-100 tracking-tight">PrintLabel</span>
        </a>

        <!-- Nav links -->
        <nav class="hidden md:flex items-center gap-1">
          <a href="/packing-lists" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'lists' ? 'active' : '' %>">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
            </svg>
            Packing Lists
          </a>
          <a href="/packing-lists/upload" class="nav-link <%= typeof activePage !== 'undefined' && activePage === 'upload' ? 'active' : '' %>">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" />
            </svg>
            Upload
          </a>
        </nav>

        <!-- User info -->
        <div class="flex items-center gap-3">
          <div class="hidden sm:flex items-center gap-2 px-3 py-1.5 rounded-lg bg-surface-800 border border-surface-700/50">
            <div class="w-6 h-6 rounded-full bg-brand-600 flex items-center justify-center">
              <span class="text-xs font-bold text-white"><%= currentUser.name.charAt(0).toUpperCase() %></span>
            </div>
            <span class="text-sm text-slate-300 font-medium"><%= currentUser.name %></span>
          </div>
          <a href="/logout" class="btn btn-secondary btn-sm">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
            </svg>
            Logout
          </a>
        </div>

      </div>
    </div>
  </header>
  <% } %>

  <!-- Main Content -->
  <main class="flex-1">
    <%- body %>
  </main>

  <!-- Footer -->
  <% if (currentUser) { %>
  <footer class="border-t border-surface-700/30 py-4 mt-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs text-slate-600 text-center">
        PrintLabel &copy; <%= new Date().getFullYear() %> — Packing Label Generator
      </p>
    </div>
  </footer>
  <% } %>

  <script src="/js/app.js"></script>
</body>
</html>
