<!DOCTYPE html>
<html lang="en" class="h-full">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>
    <%= title %>
  </title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>

<body class="min-h-full bg-surface-950 text-slate-100">

  <%- include('../partials/navbar', { activePage: 'users' }) %>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

      <!-- Page header -->
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
          <h1 class="page-title">
            <%= __('usr_title') %>
          </h1>
          <p class="page-subtitle">
            <%= __('usr_subtitle') %>
          </p>
        </div>
        <a href="/users/new" id="addUserBtn" class="btn btn-primary">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          <%= __('usr_btn_add') %>
        </a>
      </div>

      <%- include('../partials/flash') %>

        <!-- Users table -->
        <div class="card overflow-hidden animate-slide-up">
          <div class="card-header flex items-center justify-between">
            <h2 class="font-semibold text-slate-200 flex items-center gap-2">
              <svg class="w-4 h-4 text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <%= __('usr_all_users') %>
            </h2>
            <span class="badge badge-brand">
              <%= users.length %>
                <%= __('usr_users_count') %>
            </span>
          </div>
          <div class="overflow-x-auto">
            <table class="table-base" id="usersTable">
              <thead>
                <tr>
                  <th>#</th>
                  <th>
                    <%= __('usr_col_name') %>
                  </th>
                  <th>
                    <%= __('usr_col_email') %>
                  </th>
                  <th>
                    <%= __('usr_col_role') %>
                  </th>
                  <th>
                    <%= __('usr_col_joined') %>
                  </th>
                  <th class="text-right">
                    <%= __('usr_col_actions') %>
                  </th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(function(u, idx) { %>
                  <tr>
                    <td class="font-mono text-slate-500 text-xs">
                      <%= idx + 1 %>
                    </td>
                    <td>
                      <div class="flex items-center gap-2.5">
                        <div
                          class="w-8 h-8 rounded-full bg-gradient-to-br from-brand-600 to-brand-800 flex items-center justify-center flex-shrink-0">
                          <span class="text-xs font-bold text-white">
                            <%= u.name.charAt(0).toUpperCase() %>
                          </span>
                        </div>
                        <span class="font-medium text-slate-200">
                          <%= u.name %>
                        </span>
                      </div>
                    </td>
                    <td class="text-slate-400 font-mono text-xs">
                      <%= u.email %>
                    </td>
                    <td>
                      <% if (u.role==='admin' ) { %>
                        <span class="badge badge-admin">
                          <svg class="w-3 h-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                              d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                              clip-rule="evenodd" />
                          </svg>
                          <%= __('usr_badge_admin') %>
                        </span>
                        <% } else { %>
                          <span class="badge badge-checker">
                            <%= __('usr_badge_checker') %>
                          </span>
                          <% } %>
                    </td>
                    <td class="text-slate-500 text-xs">
                      <%= new Date(u.created_at).toLocaleDateString('en-GB', { dateStyle: 'medium' }) %>
                    </td>
                    <td class="text-right">
                      <div class="flex items-center justify-end gap-2">
                        <a href="/users/<%= u.id %>/edit" id="editUser<%= u.id %>" class="btn btn-secondary btn-sm">
                          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                            stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round"
                              d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                          </svg>
                          <%= __('usr_action_edit') %>
                        </a>
                        <% if (u.email !=='admin@printlabel.com' && u.id !==currentUser.id) { %>
                          <% const confirmMsg = __("usr_confirm_delete", u.name); %>
                          <form action="/users/<%= u.id %>/delete" method="POST" onsubmit="return confirm('<%= confirmMsg %>')">
                            <button type="submit" id="deleteUser<%= u.id %>" class="btn btn-danger btn-sm">
                              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                              </svg>
                              <%= __('usr_action_delete') %>
                            </button>
                          </form>
                          <% } else { %>
                            <span class="text-slate-600 text-xs px-2">
                              <%= __('usr_protected') %>
                            </span>
                            <% } %>
                      </div>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
        </div>

    </main>

    <footer class="border-t border-surface-700/30 py-4 mt-8">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-xs text-slate-600 text-center">PrintLabel &copy; <%= new Date().getFullYear() %>
        </p>
      </div>
    </footer>

    <script src="/js/app.js"></script>
</body>

</html>