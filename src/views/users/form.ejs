<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="min-h-full bg-surface-950 text-slate-100">

  <%- include('../partials/navbar', { activePage: 'users' }) %>

  <main class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-slate-500 mb-6">
      <a href="/users" class="hover:text-slate-300 transition-colors">Users</a>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
      <span class="text-slate-400"><%= isEdit ? 'Edit User' : 'Add User' %></span>
    </nav>

    <!-- Page header -->
    <div class="mb-8">
      <h1 class="page-title"><%= isEdit ? __('uf_edit_title') : __('uf_add_title') %></h1>
      <p class="page-subtitle"><%= isEdit ? __('uf_edit_subtitle') : __('uf_add_subtitle') %></p>
    </div>

    <%- include('../partials/flash') %>

    <!-- Form card -->
    <div class="card animate-slide-up">
      <!-- Accent top bar -->
      <div class="h-1 bg-gradient-to-r from-brand-500 via-brand-400 to-brand-600 rounded-t-2xl"></div>

      <div class="card-body space-y-5 pt-6">
        <form action="<%= action %>" method="POST" id="userForm">

          <!-- Name -->
          <div>
            <label for="userName" class="label-text"><%= __('uf_lbl_name') %></label>
            <input
              type="text"
              id="userName"
              name="name"
              value="<%= formUser.name %>"
              placeholder="e.g. Budi Santoso"
              required
              autocomplete="name"
              class="input"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="userEmail" class="label-text"><%= __('uf_lbl_email') %></label>
            <input
              type="email"
              id="userEmail"
              name="email"
              value="<%= formUser.email %>"
              placeholder="user@example.com"
              required
              autocomplete="email"
              class="input"
              <% if (isEdit && formUser.email === 'admin@printlabel.com') { %>readonly style="opacity:0.6;cursor:not-allowed"<% } %>
            />
            <% if (isEdit && formUser.email === 'admin@printlabel.com') { %>
            <p class="text-xs text-amber-400 mt-1.5">⚠️ <%= __('uf_email_admin_warn') %></p>
            <% } %>
          </div>

          <!-- Role -->
          <div>
            <label class="label-text"><%= __('uf_lbl_role') %></label>
            <div class="flex gap-3 mt-1">
              <label class="flex-1 flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition-all
                <%= formUser.role === 'checker' ? 'border-brand-500/60 bg-brand-900/20' : 'border-surface-700/60 bg-surface-800/50 hover:border-surface-600' %>">
                <input type="radio" name="role" value="checker"
                  <%= formUser.role !== 'admin' ? 'checked' : '' %>
                  class="accent-brand-500"
                  <% if (isEdit && formUser.email === 'admin@printlabel.com') { %>disabled<% } %>
                />
                <div>
                  <p class="text-sm font-semibold text-slate-200"><%= __('uf_role_checker_title') %></p>
                  <p class="text-xs text-slate-500"><%= __('uf_role_checker_desc') %></p>
                </div>
              </label>
              <label class="flex-1 flex items-center gap-3 p-3 rounded-xl border cursor-pointer transition-all
                <%= formUser.role === 'admin' ? 'border-brand-500/60 bg-brand-900/20' : 'border-surface-700/60 bg-surface-800/50 hover:border-surface-600' %>">
                <input type="radio" name="role" value="admin"
                  <%= formUser.role === 'admin' ? 'checked' : '' %>
                  class="accent-brand-500"
                  <% if (isEdit && formUser.email === 'admin@printlabel.com') { %>disabled<% } %>
                />
                <div>
                  <p class="text-sm font-semibold text-slate-200"><%= __('uf_role_admin_title') %></p>
                  <p class="text-xs text-slate-500"><%= __('uf_role_admin_desc') %></p>
                </div>
              </label>
            </div>
          </div>

          <!-- Password -->
          <div>
            <label for="userPassword" class="label-text">
              <%= __('uf_lbl_pw') %> <% if (isEdit) { %><span class="text-slate-600 font-normal normal-case"><%= __('uf_pw_edit_hint') %></span><% } %>
            </label>
            <div class="relative">
              <input
                type="password"
                id="userPassword"
                name="password"
                placeholder="<%= isEdit ? __('uf_pw_edit_placeholder') : __('uf_pw_add_placeholder') %>"
                <%= !isEdit ? 'required' : '' %>
                minlength="<%= !isEdit ? '6' : '0' %>"
                autocomplete="<%= isEdit ? 'new-password' : 'new-password' %>"
                class="input pr-11"
              />
              <button type="button" id="togglePw"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-500 hover:text-slate-300 transition-colors"
                aria-label="Toggle password">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
              </button>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex gap-3 pt-2">
            <a href="/users" class="btn btn-secondary flex-1 justify-center"><%= __('uf_btn_cancel') %></a>
            <button type="submit" id="submitBtn" class="btn btn-primary flex-2 justify-center" style="flex:2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <%= isEdit ? __('uf_btn_save') : __('uf_btn_create') %>
            </button>
          </div>

        </form>
      </div>
    </div>

  </main>

  <script>
    // Toggle password visibility
    const toggleBtn = document.getElementById('togglePw');
    const pwInput   = document.getElementById('userPassword');
    if (toggleBtn && pwInput) {
      toggleBtn.addEventListener('click', () => {
        pwInput.type = pwInput.type === 'password' ? 'text' : 'password';
      });
    }

    // Role selector visual update
    document.querySelectorAll('input[name="role"]').forEach(radio => {
      radio.addEventListener('change', () => {
        document.querySelectorAll('label:has(input[name="role"])').forEach(lbl => {
          const inp = lbl.querySelector('input');
          if (inp.checked) {
            lbl.classList.add('border-brand-500/60', 'bg-brand-900/20');
            lbl.classList.remove('border-surface-700/60', 'bg-surface-800/50');
          } else {
            lbl.classList.remove('border-brand-500/60', 'bg-brand-900/20');
            lbl.classList.add('border-surface-700/60', 'bg-surface-800/50');
          }
        });
      });
    });

    // Disable on submit
    document.getElementById('userForm').addEventListener('submit', function() {
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.style.opacity = '0.7';
    });
  </script>
  <script src="/js/app.js"></script>
</body>
</html>
